---
import { getEntry } from 'astro:content';
import SectionContainer from './SectionContainer.astro';

const flowData = await getEntry('home', 'flow');
const { title, steps } = flowData.data;
---

<section class="py-24 bg-white">
  <SectionContainer>
    <div class="text-center mb-20">
      <h2 class="text-4xl md:text-5xl font-serif text-main-1">{title}</h2>
    </div>

    <div class="grid md:grid-cols-4 gap-12 relative">
      {steps.map((item, index) => (
        <div class="relative flex flex-col items-center text-center group">
          
          {/* ステップ番号：背景との対比で浮き上がらせる */}
          <div class="w-20 h-20 rounded-full bg-white border-2 border-main-1 flex items-center justify-center text-3xl font-serif text-main-1 mb-8 shadow-sm group-hover:bg-main-1 group-hover:text-white transition-colors duration-500">
            {item.step}
          </div>
          
          <h3 class="text-2xl font-serif font-bold text-black-1 mb-4">{item.name}</h3>
          <p class="text-lg text-black-1/70 leading-relaxed max-w-xs">
            {item.description}
          </p>

          {/* 連結線（PC時のみ表示） */}
          {index < steps.length - 1 && (
            <div class="hidden md:block absolute top-10 left-[calc(50%+40px)] w-[calc(100%-80px)] h-px border-t border-dashed border-main-1/30 -z-10"></div>
          )}
        </div>
      ))}
    </div>
  </SectionContainer>
</section>