---
import { getEntry } from 'astro:content';
import SectionContainer from './SectionContainer.astro';

const flowData = await getEntry('home', 'flow');
const { title, steps } = flowData.data;
---

<section class="py-24 md:py-32 bg-clr-base-1 text-clr-wh-1 relative overflow-hidden">
  <SectionContainer>
    <div class="text-center mb-20">
      <h2 class="text-3xl md:text-4xl font-serif text-clr-main-1 tracking-widest uppercase">
        {title}
      </h2>
      <div class="w-20 h-px bg-clr-main-1 mx-auto mt-6"></div>
    </div>

    {/* PC時はグリッドで等間隔に配置し、線を中央に通す */}
    <div class="grid md:grid-cols-4 gap-8 relative">
      {/* 連結線：PC時のみ、grid全体の中央を通す */}
      <div class="hidden md:block absolute top-8 left-[12.5%] right-[12.5%] h-px border-t border-dashed border-clr-main-1/30"></div>

      {steps.map((item, index) => {
        const romanNumbers = ["I", "II", "III", "IV"];
        
        return (
          <div class="relative flex flex-col items-center text-center group z-10">
            {/* ステップ番号：背景色の指定により線が背後を通るようにする */}
            <div class="w-16 h-16 border border-clr-main-1 flex items-center justify-center text-2xl font-serif text-clr-main-1 mb-6 bg-clr-base-1 group-hover:bg-clr-main-1 group-hover:text-clr-base-1 transition-all duration-500">
              {romanNumbers[index] || item.step}
            </div>
            
            <h3 class="text-xl font-serif text-clr-wh-1 mb-4">
              {item.name}
            </h3>
            
            {/* 説明文のみ左寄せ */}
            <p class="text-base text-clr-bl-1 leading-relaxed text-left w-full max-w-[240px]">
              {item.description}
            </p>
          </div>
        );
      })}
    </div>
  </SectionContainer>
</section>