---
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { OWNER_NAME } from '../data/site';
import tarot0 from '../assets/images/tarot/tarot_majar_arcana_21.webp';
import tarot1 from '../assets/images/tarot/tarot_majar_arcana_17.webp';
import tarot2 from '../assets/images/tarot/tarot_majar_arcana_10.webp';
import SectionContainer from './SectionContainer.astro';

const greetingData = (await getEntry('home', 'greeting'))!;
const content = greetingData.data.content.replace('{NAME}', OWNER_NAME);
const { title } = greetingData.data;
---

<section class="relative py-24 bg-clr-base-1 overflow-hidden">
  {/* 装飾：ゴールドの煌めきを想起させる薄い配置 */}
  <div class="absolute -top-60 -right-10 w-64 opacity-5 rotate-12 pointer-events-none grayscale brightness-200">
    <Image src={tarot0} alt="" />
  </div>
  <div class="absolute top-100 -left-20 w-64 opacity-5 -rotate-14 pointer-events-none grayscale brightness-200">
    <Image src={tarot1} alt="" />
  </div>
  <div class="absolute top-130 left-20 w-64 opacity-5 -rotate-7 pointer-events-none grayscale brightness-200">
    <Image src={tarot2} alt="" />
  </div>

  <SectionContainer class="flex flex-col items-center text-center relative z-10">
    <div class="max-w-3xl space-y-10">
      <h2 class="text-3xl md:text-4xl font-serif text-clr-main-1 tracking-widest uppercase">
        {title}
      </h2>
      
      <div class="max-w-2xl mx-auto space-y-6">
        <p class="text-clr-wh-1 font-serif text-lg md:text-xl leading-loose whitespace-pre-line opacity-90">
          {content}
        </p>
      </div>

      <div class="flex justify-center pt-4">
        {/* 装飾ラインをゴールドに変更 */}
        <div class="w-24 h-px bg-clr-main-1"></div>
      </div>
    </div>
  </SectionContainer>
</section>