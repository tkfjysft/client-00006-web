---
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import profileImage from '../assets/images/owner/face_owner.webp';
import SectionContainer from './SectionContainer.astro';
import { OWNER_NAME } from '../data/site';

const data = await getEntry('home', 'profile');
if (!data) throw new Error("profile.jsonが見つかりません");

const { title, text, tags } = data.data;
---

<section class="py-24 md:py-32 bg-clr-base-1 text-clr-wh-1">
  <SectionContainer>
    <div class="text-center mb-20">
      <h2 class="text-3xl md:text-4xl font-serif text-clr-main-1 tracking-widest uppercase">
        {title}
      </h2>
      <div class="w-20 h-px bg-clr-main-1 mx-auto mt-8"></div>
    </div>
    
    <div class="flex flex-col md:flex-row items-start gap-16 max-w-5xl mx-auto">
      
      {/* 写真エリア：角を活かした重厚なスタイル */}
      <div class="relative flex-shrink-0 mx-auto md:mx-0">
        <div class="absolute -top-4 -left-4 w-full h-full border border-clr-main-1/30"></div>
        <Image 
          src={profileImage} 
          alt={OWNER_NAME} 
          class="shadow-2xl w-[280px] md:w-[320px] aspect-[4/5] object-cover grayscale brightness-90 border border-clr-main-1/20" 
        />
      </div>
      
      {/* 紹介テキストエリア */}
      <div class="space-y-10">
        <div>
          <p class="text-base tracking-[0.2em] text-clr-main-1/70 uppercase mb-4">Profile</p>
          <h3 class="text-3xl md:text-4xl font-serif text-clr-wh-1">{OWNER_NAME}</h3>
        </div>
        
        <p class="text-base md:text-lg text-clr-wh-1/90 leading-relaxed whitespace-pre-line">
          {text}
        </p>

        {/* タグエリア：四角形の枠で統一 */}
        <div class="flex flex-wrap gap-4 pt-4">
          {tags.map((tag) => (
            <span class="px-6 py-3 border border-clr-main-1/30 text-clr-main-1 text-base font-medium">
              {tag}
            </span>
          ))}
        </div>
      </div>
    </div>
  </SectionContainer>
</section>