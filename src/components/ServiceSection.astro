---
import { getEntry } from 'astro:content';
import SectionContainer from './SectionContainer.astro';
import { Clock, Sparkles, CircleCheck } from 'lucide-astro';

const serviceData = await getEntry('home', 'service');
if (!serviceData) throw new Error("service.jsonが見つかりません");

const { title, description, items } = serviceData.data;
---

<section class="py-32 bg-clr-base-1 relative overflow-hidden">
  {/* 背景に淡い光のグラデーションを配置して神秘性を演出 */}
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full opacity-20 pointer-events-none bg-[radial-gradient(circle_at_top,var(--color-clr-main-1),transparent_70%)]"></div>

  <SectionContainer>
    <div class="text-center mb-20">
      <h2 class="text-4xl md:text-6xl font-serif text-clr-wh-1 tracking-widest mb-6">
        {title}
      </h2>
      <div class="w-16 h-px bg-clr-main-1 mx-auto mb-6"></div>
      <p class="text-clr-bl-1 text-lg max-w-lg mx-auto leading-relaxed">{description}</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {items.map((item) => (
        <div class="relative group bg-clr-base-1 border border-clr-wh-1/10 p-10 hover:border-clr-main-1/50 transition-all duration-700">
          
          {/* カード上部の光の演出 */}
          <div class="absolute inset-0 bg-gradient-to-b from-clr-main-1/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

          <div class="relative z-10 flex flex-col h-full">
            <h3 class="text-2xl font-serif text-clr-main-1 mb-6 border-b border-clr-main-1/20 pb-4">
              {item.name}
            </h3>
            
            <div class="flex items-center gap-4 text-clr-accent-1 mb-8">
              <Clock class="w-5 h-5" />
              <div class="flex flex-col">
                <span class="text-xl font-bold tracking-wider">{item.time}</span>
                <span class="text-sm opacity-70 tracking-widest">{item.price}</span>
              </div>
            </div>
            
            <p class="text-clr-bl-1 text-base leading-relaxed mb-10 flex-grow">
              {item.description}
            </p>
            
            <ul class="space-y-3">
              {item.features.map((feature) => (
                <li class="flex items-center text-clr-wh-1/80 text-sm tracking-wide">
                  <span class="mr-3 text-clr-main-1">✦</span>
                  {feature}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </SectionContainer>
</section>