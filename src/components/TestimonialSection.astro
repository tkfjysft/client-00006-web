---
import { getEntry } from 'astro:content';
import SectionContainer from './SectionContainer.astro';
import { Quote, User } from 'lucide-astro'; // Userアイコンを追加

const reviewData = await getEntry('home', 'testimonials');
if (!reviewData) throw new Error("reviews.jsonが見つかりません");

const { title, reviews } = reviewData.data;
---

<section class="py-24 bg-base-1">
  <SectionContainer>
    <div class="text-center mb-20">
      <h2 class="text-4xl md:text-5xl font-serif text-main-1">{title}</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      {reviews.map((review) => (
        <div class="p-10 border border-main-1/10 rounded-3xl bg-white shadow-sm hover:shadow-lg transition-all duration-500 relative flex flex-col">
          
          <Quote class="w-10 h-10 text-main-1 opacity-20 mb-6" />

          <p class="text-lg text-black-1/80 leading-relaxed mb-8 flex-grow italic">
            "{review.comment}"
          </p>

          <div class="border-t border-main-1/10 pt-6 flex items-center gap-4">
            {/* 丸枠に入った人型アイコン */}
            <div class="w-12 h-12 rounded-full bg-main-1/5 flex items-center justify-center border border-main-1/20">
              <User class="w-6 h-6 text-main-1/60" />
            </div>
            <div>
              <p class="text-base font-bold text-main-1 mb-0.5">{review.name}</p>
              <p class="text-base text-black-1/60">{review.topic}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </SectionContainer>
</section>