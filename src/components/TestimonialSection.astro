---
import { getEntry } from 'astro:content';
import SectionContainer from './SectionContainer.astro';
import { Quote, User } from 'lucide-astro';

const reviewData = await getEntry('home', 'testimonials');
if (!reviewData) throw new Error("reviews.jsonが見つかりません");

const { title, reviews } = reviewData.data;
---

<section class="py-24 md:py-32 bg-clr-base-1 text-clr-wh-1">
  <SectionContainer>
    <div class="text-center mb-20">
      <h2 class="text-3xl md:text-4xl font-serif text-clr-main-1 tracking-widest uppercase">
        {title}
      </h2>
      <div class="w-20 h-px bg-clr-main-1 mx-auto mt-8"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      {reviews.map((review) => (
        <div class="p-8 md:p-10 border border-clr-main-1/20 bg-clr-base-1 hover:border-clr-main-1/50 transition-all duration-500 flex flex-col">
          
          <Quote class="w-8 h-8 text-clr-main-1 mb-6 opacity-50" />

          <p class="text-base md:text-lg text-clr-wh-1/90 leading-relaxed mb-10 flex-grow italic">
            "{review.comment}"
          </p>

          <div class="border-t border-clr-main-1/20 pt-8 flex items-center gap-5">
            {/* 四角形のアイコン枠に変更して統一感を持たせました */}
            <div class="w-14 h-14 border border-clr-main-1/30 flex items-center justify-center bg-clr-base-1">
              <User class="w-7 h-7 text-clr-main-1" />
            </div>
            <div>
              <p class="text-lg font-bold text-clr-main-1 mb-1">{review.name}</p>
              <p class="text-base text-clr-bl-1">{review.topic}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </SectionContainer>
</section>